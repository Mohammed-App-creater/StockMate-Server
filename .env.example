# Database (async driver, e.g. postgresql+asyncpg://user:pass@host:5432/dbname)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockmate

# Auth / JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Cloudflare R2 object storage
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
PUBLIC_URL=
